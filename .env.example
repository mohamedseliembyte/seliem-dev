# =============================================================================
# seliem.dev — environment variables
# Copy to .env.local for development. Set the same vars in Vercel for prod.
# NEXT_PUBLIC_* vars are exposed to the browser; everything else is server-only.
# =============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
# Browser (publishable / anon) key — used by the client Supabase instance.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only SECRET (service-role) key — bypasses RLS. NEVER expose to the browser.
SUPABASE_SECRET_KEY=

# ── Google Sign-In ───────────────────────────────────────────────────────────
# Google Identity Services OAuth client ID for the account sign-in popup.
# Falls back to the historical literal in src/lib/google-auth.ts if unset, but
# you should set this explicitly so the ID is not hardcoded.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Groq (AI concierge + admin assistant) ────────────────────────────────────
GROQ_API_KEY=

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=noreply@seliem.dev
CONTACT_TO_EMAIL=mohamed.seliem.dev@gmail.com
SUPPORT_EMAIL=support@seliem.dev

# ── Telegram (lead alerts + admin assistant bot) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Secret token verified on every inbound webhook request. REQUIRED — if unset,
# the webhook rejects all requests. Register it with the webhook's secret_token.
TELEGRAM_WEBHOOK_SECRET=

# ── Admin access ─────────────────────────────────────────────────────────────
# Comma-separated list of emails allowed to use admin API routes.
# Required. Comma-separated allow-list; admin APIs deny everyone when empty.
ADMIN_EMAIL=

# ── Cron protection ──────────────────────────────────────────────────────────
# Required. Vercel Cron sends "Authorization: Bearer <CRON_SECRET>".
# Cron routes deny every request when this is empty.
CRON_SECRET=

# ── PayPal ───────────────────────────────────────────────────────────────────
# Your paypal.me handle (e.g. "mohamedseliem"); used to build payment links.
NEXT_PUBLIC_PAYPAL_HANDLE=

# ── Conversation retention (archival cron) ───────────────────────────────────
# Conversations/messages with no activity for this many days are archived/deleted.
CONVERSATION_RETENTION_DAYS=365
